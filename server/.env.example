# =============================================================================
# Table Canvas Server - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# MongoDB Connection
# -----------------------------------------------------------------------------
# Local development:
MONGODB_URI=mongodb://localhost:27017/table-canvas

# MongoDB Atlas (production example):
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/table-canvas?retryWrites=true&w=majority

# -----------------------------------------------------------------------------
# JWT Secrets (REQUIRED - generate strong random strings for production)
# -----------------------------------------------------------------------------
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your-access-token-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production

# Token expiration times
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=3001
NODE_ENV=development
# Defaults to false in production and true outside production.
ENABLE_REGISTRATION=false

# -----------------------------------------------------------------------------
# CORS / Frontend URL
# -----------------------------------------------------------------------------
# Development:
FRONTEND_URL=http://localhost:5173
# Comma-separated trusted reverse-proxy ranges. Never use true in production.
TRUST_PROXY=loopback, linklocal, uniquelocal

# Production example:
# FRONTEND_URL=https://your-domain.com

# -----------------------------------------------------------------------------
# Google Sign-In (required in production; optional for local development)
# -----------------------------------------------------------------------------
# Get your client ID from https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
