{
  "name": "table-canvas",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --reporter=verbose",
    "test:engine": "vitest run src/engine/*.test.ts --reporter=verbose",
    "test:formula": "vitest run src/formula/*.test.ts --reporter=verbose",
    "test:persistence": "vitest run src/persistence/*.test.ts --reporter=verbose",
    "test:suggestions": "vitest run src/suggestions/*.test.ts --reporter=verbose",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:unit && npm run test:e2e",
    "test:ci": "vitest run --reporter=junit --outputFile=./test-results/junit.xml",
    "seed": "npm run seed --prefix server",
    "docker:up": "./scripts/docker-up.sh",
    "docker:up:attached": "docker compose up --build",
    "docker:down": "./scripts/docker-down.sh",
    "docker:down:volumes": "echo '' && echo '⏳ Stopping and removing data...' && docker compose down -v > /dev/null 2>&1 && echo '✅ Stopped and removed database!' && echo ''",
    "docker:logs": "docker compose logs -f frontend backend",
    "docker:restart": "docker compose down && docker compose up --build",
    "docker:seed": "docker compose exec backend npm run seed"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "^1.33.1-dev16.0",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@tiptap/extension-highlight": "^3.17.0",
    "@tiptap/extension-link": "^3.17.0",
    "@tiptap/extension-placeholder": "^3.17.0",
    "@tiptap/extension-typography": "^3.17.0",
    "@tiptap/extension-underline": "^3.17.0",
    "@tiptap/pm": "^3.17.0",
    "@tiptap/react": "^3.17.0",
    "@tiptap/starter-kit": "^3.17.0",
    "@tiptap/suggestion": "^3.17.0",
    "@types/dagre": "^0.7.53",
    "dagre": "^0.8.5",
    "file-saver": "^2.0.5",
    "html2pdf.js": "^0.14.0",
    "idb": "^8.0.1",
    "immer": "^10.1.1",
    "jszip": "^3.10.1",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.21.1",
    "reactflow": "^11.11.4",
    "recharts": "^2.15.0",
    "tippy.js": "^6.3.7",
    "turndown": "^7.2.2",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.10.5",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^27.4.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.53.1",
    "vite": "^6.0.5",
    "vitest": "^4.0.17"
  }
}
