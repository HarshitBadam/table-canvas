# =============================================================================
# Table Canvas Client - Environment Variables (Vite)
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Variables must be prefixed with VITE_ to be exposed to the client bundle.
# IMPORTANT: Never commit .env to version control!
# =============================================================================

# Backend API URL (default: http://localhost:3001/api)
# VITE_API_URL=http://localhost:3001/api

# -----------------------------------------------------------------------------
# Google Sign-In (optional — button hidden when not configured)
# -----------------------------------------------------------------------------
# Must match the GOOGLE_CLIENT_ID used by the server.
# Get your client ID from https://console.cloud.google.com/apis/credentials
# VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
